// SQLite-compatible schema for testing
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum SubscriptionLevel {
  free
  premium
  teacher
}

enum StoryType {
  narrative
  dialogue
  news
  essay
}

enum DifficultyLevel {
  beginner
  intermediate
  advanced
}

enum UploadStatus {
  pending
  processing
  completed
  failed
}

// ==================== MODELS ====================

model User {
  id                  String            @id @default(cuid())
  username            String            @unique
  email               String            @unique
  passwordHash        String            @map("password_hash")
  subscriptionLevel   SubscriptionLevel @default(free) @map("subscription_level")
  learningPreferences String?           @default("{}") @map("learning_preferences") // JSON as String
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @default(now()) @updatedAt @map("updated_at")
  lastLogin           DateTime?         @map("last_login")

  vocabularyLists  VocabularyList[]
  generatedStories GeneratedStory[]
  quizzes          Quiz[]
  quizAttempts     QuizAttempt[]
  userProgress     UserProgress[]
  fileUploads      FileUpload[]
  userSessions     UserSession[]

  @@map("users")
}

model VocabularyList {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  name            String
  description     String?
  sourceFileName  String?  @map("source_file_name")
  sourceFileUrl   String?  @map("source_file_url")
  totalWords      Int      @default(0) @map("total_words")
  hskDistribution String?  @default("{}") @map("hsk_distribution") // JSON as String
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabularyItems  VocabularyItem[]
  generatedStories GeneratedStory[]
  quizzes          Quiz[]
  fileUploads      FileUpload[]

  @@index([userId])
  @@map("vocabulary_lists")
}

model VocabularyItem {
  id                 String   @id @default(cuid())
  vocabularyListId   String   @map("vocabulary_list_id")
  simplified         String
  traditional        String?
  pinyin             String?
  englishDefinitions String   @map("english_definitions") // JSON array as String
  hskLevel           Int?     @map("hsk_level")
  frequencyScore     Float    @default(0) @map("frequency_score")
  partOfSpeech       String?  @map("part_of_speech")
  exampleSentences   String   @default("[]") @map("example_sentences") // JSON array as String
  userNotes          String?  @map("user_notes")
  masteryLevel       Int      @default(0) @map("mastery_level")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  vocabularyList VocabularyList @relation(fields: [vocabularyListId], references: [id], onDelete: Cascade)
  userProgress   UserProgress[]

  @@index([vocabularyListId])
  @@index([simplified])
  @@index([hskLevel])
  @@index([vocabularyListId, hskLevel])
  @@map("vocabulary_items")
}

model GeneratedStory {
  id               String          @id @default(cuid())
  userId           String          @map("user_id")
  vocabularyListId String          @map("vocabulary_list_id")
  title            String
  storyType        StoryType       @default(narrative) @map("story_type")
  difficultyLevel  DifficultyLevel @default(intermediate) @map("difficulty_level")
  content          String          @map("content") // JSON as String
  vocabularyUsed   String          @default("[]") @map("vocabulary_used") // JSON array as String
  regenerationCount Int            @default(0) @map("regeneration_count")
  createdAt        DateTime        @default(now()) @map("created_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabularyList VocabularyList @relation(fields: [vocabularyListId], references: [id], onDelete: Cascade)
  quizzes        Quiz[]

  @@index([userId])
  @@index([vocabularyListId])
  @@map("generated_stories")
}

model Quiz {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  vocabularyListId String?  @map("vocabulary_list_id")
  storyId          String?  @map("story_id")
  title            String?
  questions        String   @map("questions") // JSON as String
  totalQuestions   Int      @map("total_questions")
  createdAt        DateTime @default(now()) @map("created_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabularyList VocabularyList? @relation(fields: [vocabularyListId], references: [id], onDelete: Cascade)
  story          GeneratedStory? @relation(fields: [storyId], references: [id], onDelete: SetNull)
  quizAttempts   QuizAttempt[]

  @@index([userId])
  @@index([vocabularyListId])
  @@map("quizzes")
}

model QuizAttempt {
  id               String   @id @default(cuid())
  quizId           String   @map("quiz_id")
  userId           String   @map("user_id")
  userAnswers      String   @map("user_answers") // JSON as String
  score            Float    // 0-1 scale
  timeSpentSeconds Int?     @map("time_spent_seconds")
  completedAt      DateTime @default(now()) @map("completed_at")

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
  @@map("quiz_attempts")
}

model UserProgress {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  vocabularyItemId String    @map("vocabulary_item_id")
  masteryLevel     Int       @default(0) @map("mastery_level")
  correctAnswers   Int       @default(0) @map("correct_answers")
  totalAttempts    Int       @default(0) @map("total_attempts")
  lastPracticed    DateTime? @map("last_practiced")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabularyItem VocabularyItem @relation(fields: [vocabularyItemId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyItemId])
  @@index([userId])
  @@index([masteryLevel])
  @@index([userId, masteryLevel])
  @@map("user_progress")
}

model FileUpload {
  id               String       @id @default(cuid())
  userId           String       @map("user_id")
  originalFilename String       @map("original_filename")
  fileSize         Int          @map("file_size") // Changed from BigInt
  fileType         String       @map("file_type")
  storageKey       String       @map("storage_key")
  processingStatus UploadStatus @default(pending) @map("processing_status")
  processingError  String?      @map("processing_error")
  vocabularyListId String?      @map("vocabulary_list_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  processedAt      DateTime?    @map("processed_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabularyList VocabularyList? @relation(fields: [vocabularyListId], references: [id])

  @@index([processingStatus])
  @@index([userId, createdAt])
  @@map("file_uploads")
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  sessionToken String   @unique @map("session_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  lastUsed     DateTime @default(now()) @map("last_used")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionToken])
  @@index([expiresAt])
  @@map("user_sessions")
}